{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "image-pipeline-repomix.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 10,
    "showLineNumbers": true,
    "copyToClipboard": false
  },
  "include": [
    "lib/image-proxy.ts",
    "lib/video-overlay.ts",
    "app/api/send-stream/route.ts",
    "app/api/send-rotation/route.ts",
    "app/api/test-send/route.ts",
    "inngest/functions/scheduled-send.ts",
    "inngest/functions/scheduled-rotation-send.ts",
    "docs/image-optimization-bug-diagnostic.md"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": []
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
