{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "dreamplay-email-2-repomix.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": false,
    "copyToClipboard": false
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/*.local",
      "*repomix*",

      "components/ui/**",
      "components/editor/**",
      "components/audience/**",
      "components/campaigns-table.tsx",
      "components/chains/**",
      "components/rotation/**",
      "components/chain/**",
      "components/dashboard/**",
      "hooks/**",

      "lib/dnd-blocks/**",
      "lib/parsers/**",

      "app/editor/**",
      "app/editor-v2/**",

      "**/audience/**",
      "**/journeys/**",
      "**/migrate/**",
      "**/crm/**",
      "**/discounts/**",
      "**/assets/**",
      "**/chain-rotations/**",
      "**/chain/**",
      "**/rotation/**",
      "**/rotation-send/**",
      "**/logs/**",
      "**/triggers/**",
      "**/automated-emails/**",

      "postcss.config.mjs",
      "tsconfig.json",
      "tsconfig.tsbuildinfo",
      "next-env.d.ts",
      "pnpm-lock.yaml",
      "public/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
